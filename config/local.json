{
  "profile": "local",
  "device": "cpu",
  "total_samples": 2000,
  "network": {
    "hidden_channels": 64,
    "residual_blocks": 4,
    "policy_head_channels": 32,
    "value_head_channels": 32,
    "value_fc_hidden": 128
  },
  "mcts": {
    "n_simulations": 50,
    "c_puct": 1.5,
    "dirichlet_alpha": 0.3,
    "dirichlet_epsilon": 0.25,
    "temperature_moves": 30
  },
  "train": {
    "batch_size": 64,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "grad_clip_norm": 1.0,
    "buffer_capacity": 5000,
    "min_buffer_size": 128,
    "target_reuse": 2.0,
    "steps_per_iteration": 10,
    "weight_sync_interval": 20
  },
  "datagen": {
    "samples_dir": "data/samples",
    "model_dir": "data/models",
    "num_workers": 2,
    "games_per_worker": 1,
    "eval_batch_size": 2,
    "inference_timeout_ms": 5.0,
    "shard_games": 4,
    "max_pending_shards": 32,
    "model_export_interval": 20,
    "keep_recent_models": 3,
    "checkpoint_every": 500,
    "keep_checkpoints": 3
  }
}
