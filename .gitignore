.pycache/
__pycache__/
*.pyc

# setuptools 可编辑安装生成的包元数据（构建产物，勿入库）
*.egg-info/

# 运行日志（just selfplay / train 等）
/log/

# Runtime artifacts (samples spool, exported models, generated run-config)
# 用 /data/* 忽略内容（而非 /data/ 忽略目录本身），以便给个别契约文件单独放行
/data/*
# 冻结的 arena 开局是可复现契约（需入库、跨机一致），单独放行；report/table 仍当产物忽略
!/data/arena/
/data/arena/*
!/data/arena/openings.json

# 导出的模型权重（本地 `export_initial_model.py` / train 生成，勿入库）
/data/models/
/trainer/data/models/
*.pt

# Rust build output
target/
perf.data
flamegraph.svg

# Python venv
.venv/

# Python version (per-machine, not committed)
.python-version

# Environment variables (per-machine)
.env

local

config.local.json
