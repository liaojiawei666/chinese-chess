{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "chinese-chess run-config",
  "description": "跨语言运行配置：trainer(Python) 与 datagen(Rust) 的可调超参数。结构常量（棋盘几何、规则上限、编码通道数）定义在代码中，不重复写入。",
  "type": "object",
  "required": ["profile", "device", "total_samples", "network", "mcts", "train", "datagen"],
  "additionalProperties": false,
  "properties": {
    "profile": { "type": "string" },
    "device": { "type": "string", "enum": ["cpu", "cuda", "auto"] },
    "total_samples": { "type": "integer", "minimum": 1 },
    "network": {
      "type": "object",
      "required": ["hidden_channels", "residual_blocks", "policy_head_channels", "value_head_channels", "value_fc_hidden"],
      "additionalProperties": false,
      "properties": {
        "hidden_channels": { "type": "integer" },
        "residual_blocks": { "type": "integer" },
        "policy_head_channels": { "type": "integer" },
        "value_head_channels": { "type": "integer" },
        "value_fc_hidden": { "type": "integer" }
      }
    },
    "mcts": {
      "type": "object",
      "required": ["n_simulations", "c_puct", "dirichlet_alpha", "dirichlet_epsilon"],
      "additionalProperties": false,
      "properties": {
        "n_simulations": { "type": "integer", "minimum": 1 },
        "c_puct": { "type": "number" },
        "dirichlet_alpha": { "type": "number" },
        "dirichlet_epsilon": { "type": "number" },
        "temperature_moves": { "type": "integer", "minimum": 0, "default": 0, "description": "前 N 手用温度采样（训练探索用）；省略或 0 表示始终 argmax（对战用）" }
      }
    },
    "train": {
      "type": "object",
      "required": ["batch_size", "learning_rate", "weight_decay", "grad_clip_norm", "buffer_capacity", "min_buffer_size", "target_reuse", "steps_per_iteration", "weight_sync_interval"],
      "additionalProperties": false,
      "properties": {
        "batch_size": { "type": "integer" },
        "learning_rate": { "type": "number" },
        "weight_decay": { "type": "number" },
        "grad_clip_norm": { "type": "number" },
        "buffer_capacity": { "type": "integer" },
        "min_buffer_size": { "type": "integer" },
        "target_reuse": { "type": "number", "exclusiveMinimum": 0 },
        "steps_per_iteration": { "type": "integer" },
        "weight_sync_interval": { "type": "integer" }
      }
    },
    "datagen": {
      "type": "object",
      "required": ["samples_dir", "model_dir", "num_workers", "eval_batch_size", "inference_timeout_ms", "shard_games", "max_pending_shards", "model_export_interval", "keep_recent_models", "checkpoint_every", "keep_checkpoints"],
      "additionalProperties": false,
      "properties": {
        "samples_dir": { "type": "string" },
        "model_dir": { "type": "string" },
        "num_workers": { "type": "integer", "minimum": 1 },
        "games_per_worker": { "type": "integer", "minimum": 1, "default": 1 },
        "eval_batch_size": { "type": "integer", "minimum": 1 },
        "inference_timeout_ms": { "type": "number" },
        "shard_games": { "type": "integer", "minimum": 1 },
        "max_pending_shards": { "type": "integer", "minimum": 1 },
        "model_export_interval": { "type": "integer", "minimum": 1 },
        "keep_recent_models": { "type": "integer", "minimum": 1 },
        "checkpoint_every": { "type": "integer", "minimum": 1 },
        "keep_checkpoints": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
