    <mxCell id="pi" value="MCTS 分布 π" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#222222;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="116" width="90" height="36" as="geometry"/></mxCell>
    <mxCell id="ce" value="交叉熵&#10;− Σₐ πₐ log pₐ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#222222;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="210" y="78" width="170" height="52" as="geometry"/></mxCell>

    <mxCell id="v" value="价值 v" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#222222;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="172" width="90" height="36" as="geometry"/></mxCell>
    <mxCell id="z" value="对局结果 z" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#222222;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="216" width="90" height="36" as="geometry"/></mxCell>
