    <mxCell id="sum" value="总损失 L&#10;= (z−v)² − Σₐ πₐ log pₐ + λ‖θ‖²" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#222222;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="470" y="150" width="280" height="100" as="geometry"/></mxCell>

