    <mxCell id="vc" value="1×1 Conv&#10;BN · ReLU" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#222222;fontSize=11;" vertex="1" parent="1"><mxGeometry x="200" y="238" width="110" height="48" as="geometry"/></mxCell>
