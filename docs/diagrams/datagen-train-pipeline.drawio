      <mxGeometry x="100" y="430" width="320" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="bnote" value="备选 B（单局 virtual loss 批量收叶）：本机 CPU 核足够，纯 A（worker≥eval_batch_size）已能喂满 GPU；B 会破坏逐位可复现/差分测试，暂不做。" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontColor=#666666;fontSize=10;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1">
