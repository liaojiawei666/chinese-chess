    <mxCell id="ptable" value="&lt;b&gt;参数（dev=local / prod=gpu）&lt;/b&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellspacing=&quot;0&quot; cellpadding=&quot;3&quot; style=&quot;font-size:11px;border-collapse:collapse&quot;&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;参数&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;dev&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;prod&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;num_workers&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;12&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;n_simulations&lt;/td&gt;&lt;td&gt;50&lt;/td&gt;&lt;td&gt;128&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;eval_batch_size&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;16&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;inference_timeout_ms&lt;/td&gt;&lt;td&gt;5&lt;/td&gt;&lt;td&gt;5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;shard_games&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;16&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;max_pending_shards&lt;/td&gt;&lt;td&gt;32&lt;/td&gt;&lt;td&gt;256&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;buffer_capacity&lt;/td&gt;&lt;td&gt;5000&lt;/td&gt;&lt;td&gt;200000&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;batch_size&lt;/td&gt;&lt;td&gt;64&lt;/td&gt;&lt;td&gt;512&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#222222;align=center;verticalAlign=top;spacingTop=6;fontSize=11;" vertex="1" parent="1">
