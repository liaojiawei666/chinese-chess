    <mxCell id="key" value="为什么要激活函数：若只堆叠线性层，多层会塌缩成一层线性，学不出复杂棋形——激活函数提供非线性。ReLU 简单、计算快、缓解梯度消失，用于主干每个 Conv-BN 之后；tanh 把数值压到 (−1, 1)，正好对应「当前方胜负倾向」，用于 value 头输出。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#222222;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="258" width="640" height="56" as="geometry"/>
    </mxCell>
