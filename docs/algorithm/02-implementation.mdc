```python
# mcts.py — 全程用真实 Move（不碰 canonical），叶节点经 Evaluator 取 (priors, value)
class Node:
    state: GameState                 # 必须是 GameState 而非 Position（终局判定依赖历史）
    priors / visits / value_sums     # 按当前局面的合法走法存（m≈几十，远小于 8100）
    children: dict[Move, Node]

class MCTS:
    def __init__(self, evaluator: Evaluator, config: MCTSConfig | None = None, rng=None):
        self.root: Node | None = None       # 持有当前根以支持子树复用
    def run(self, root_state: GameState) -> dict[Move, int]:
        """跑 n_sim 次模拟，返回根节点各真实走法的原始访问次数 N(s,a)。
        内部职责：c_puct、根节点 Dirichlet 噪声、PUCT 选择、单局面逐个评估展开、终局用真实胜负回传。
        不负责温度与选招——只吐原始访问次数，怎么用交给上层。"""
    def advance(self, move: Move) -> None:   # 落子后把对应子树提为新根（复用）；无对应子树则置空待重建
    def reset(self) -> None:                 # 开新一局清空树
# PUCT：score = Q + c_puct·P·sqrt(1+ΣN)/(1+N)；分子用 sqrt(1+ΣN) 保证首模拟也按先验展开。
# value 符号：evaluate 返回"当前走棋方视角"估值，backup 交替取反；终局用 GameState.status() 真实胜负换算 ±1/0。
```

